#!/bin/bash

echo "# RevPi Gateway Report"
echo

if [[ -f /etc/revpi-gateway.version ]]; then
    echo "## Gateway Version"
    cat /etc/revpi-gateway.version
    echo
fi

set -uo pipefail

DEBUG="${DEBUG:-0}"
OUTFILE="${1:-}"

logerr() { echo "WARN: $*" >&2; }

NFT="$(command -v nft 2>/dev/null || true)"
IP="$(command -v ip 2>/dev/null || true)"
SS="$(command -v ss 2>/dev/null || true)"
DATE="$(date -Is)"

if [[ -z "${NFT}" || -z "${IP}" ]]; then
  echo "ERROR: nft oder ip nicht gefunden." >&2
  exit 1
fi

RULES="$($NFT -nn list ruleset 2>/dev/null || true)"
IFACES="$($IP -br a 2>/dev/null || true)"
LISTENERS_RAW=""
if [[ -n "$SS" ]]; then
  LISTENERS_RAW="$($SS -lntupH 2>/dev/null || true)"
else
  logerr "ss nicht gefunden; Listener-Abschnitt bleibt leer."
fi

TCP_INC="/etc/nftables.d/portforwards_tcp.nft"
UDP_INC="/etc/nftables.d/portforwards_udp.nft"

if [[ -z "${RULES}" ]]; then
  echo "ERROR: Konnte nftables Ruleset nicht lesen. Läuft nftables?" >&2
  exit 1
fi

WAN_IP="$(echo "$IFACES" | awk '$1=="eth1"{print $3; exit}' 2>/dev/null || true)"
LAN_IP="$(echo "$IFACES" | awk '$1=="eth0"{print $3; exit}' 2>/dev/null || true)"

IN_TCP="$(echo "$RULES" | awk '
  $1=="set" && $2=="IN_TCP" {inside=1}
  inside && $1=="elements" && $2=="=" {
    sub(/^.*\{/, "", $0); sub(/\}.*$/, "", $0);
    gsub(/[;,]/, "", $0);
    print $0; exit
  }
  inside && /}/ {inside=0}
' 2>/dev/null | tr -d ' ' || true)"

IN_UDP="$(echo "$RULES" | awk '
  $1=="set" && $2=="IN_UDP" {inside=1}
  inside && $1=="elements" && $2=="=" {
    sub(/^.*\{/, "", $0); sub(/\}.*$/, "", $0);
    gsub(/[;,]/, "", $0);
    print $0; exit
  }
  inside && /}/ {inside=0}
' 2>/dev/null | tr -d ' ' || true)"

FTP_PASV="$(echo "$RULES" | awk '
  $1=="chain" && $2=="input" {inside=1}
  inside && $0 ~ /tcp dport [0-9]+-[0-9]+ accept/ {
    for (i=1;i<=NF;i++) if ($i=="dport") print $(i+1)
  }
  inside && $1=="}" {inside=0}
' 2>/dev/null | grep -E '^[0-9]+-[0-9]+$' | head -n1 || true)"

DNAT_LINES="$(echo "$RULES" | awk '
  $1=="table" && $2=="ip" && $3=="nat" {tnat=1}
  tnat && $1=="chain" && $2=="prerouting" {inside=1}
  inside && $0 ~ /dnat to/ {print}
  inside && $1=="}" {inside=0}
' 2>/dev/null || true)"

MASQ_LINES="$(echo "$RULES" | awk '
  $1=="table" && $2=="ip" && $3=="nat" {tnat=1}
  tnat && $1=="chain" && $2=="postrouting" {inside=1}
  inside && $0 ~ /masquerade/ {print}
  inside && $1=="}" {inside=0}
' 2>/dev/null || true)"

DNAT_TABLE="$(echo "$DNAT_LINES" | awk '
  {
    proto=""; dport=""; target=""
    for (i=1;i<=NF;i++){
      if ($i=="tcp" || $i=="udp") proto=$i
      if ($i=="dport") dport=$(i+1)
      if ($i=="to") target=$(i+1)
    }
    if (proto!="" && dport!="" && target!="") {
      printf("| %s | %s | %s |\n", proto, dport, target)
    }
  }
' 2>/dev/null | sort -t'|' -k2,2n || true)"

TARGET_IPS="$(echo "$DNAT_LINES" | grep -oE 'dnat to [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' 2>/dev/null | awk '{print $3}' | sort -u | tr '\n' ' ' | sed 's/[[:space:]]*$//' || true)"

LISTENER_TABLE="| - | - | - | - |"
if [[ -n "$LISTENERS_RAW" ]]; then
  LISTENER_TABLE="$(echo "$LISTENERS_RAW" | awk '
    function procname(line,   m) { if (match(line, /\(\("([^"]+)"/, m)) return m[1]; return "-"; }
    function split_addrport(s,   m, a, p) {
      # Handles: 127.0.0.1:9090  [::1]:9090  *:41443
      a=s; p="";
      if (match(s, /(.*):([0-9*]+)$/, m)) { a=m[1]; p=m[2]; }
      gsub(/^\[/,"",a); gsub(/\]$/,"",a);
      addr=a; port=p;
    }
    {
      proto=$1;
      local=$5;
      split_addrport(local);
      proc=procname($0);
      printf("| %s | %s | %s | %s |\n", proto, addr, port, proc);
    }
  ' 2>/dev/null | sort -t'|' -k3,3n -k1,1 || true)"
fi

HINTS=""
if echo "$LISTENERS_RAW" | grep -qE '127\.0\.0\.1:9090|::1:9090|\[::1\]:9090' 2>/dev/null; then
  HINTS="${HINTS}- Cockpit (cockpit-tls) lauscht auf **localhost:9090** → von außen nicht erreichbar.\n"
fi
if echo "$LISTENERS_RAW" | grep -qE ':\b41443\b' 2>/dev/null && echo "$LISTENERS_RAW" | grep -qi apache 2>/dev/null; then
  HINTS="${HINTS}- Apache lauscht auf **41443/tcp** → Cockpit extern über **https://<IP>:41443** erreichbar.\n"
fi
if [[ -z "$HINTS" ]]; then
  HINTS="- Keine Cockpit/Apache-Hinweise erkannt.\n"
fi

TCP_INC_CONTENT="<nicht gefunden>"
UDP_INC_CONTENT="<nicht gefunden>"
if [[ -f "$TCP_INC" ]]; then TCP_INC_CONTENT="$(cat "$TCP_INC")"; fi
if [[ -f "$UDP_INC" ]]; then UDP_INC_CONTENT="$(cat "$UDP_INC")"; fi

REPORT=$(cat <<MD
# RevPi Firewall Report

Erzeugt: \`$DATE\`

## Interfaces

\`\`\`
$IFACES
\`\`\`

- WAN (eth1): **${WAN_IP:-?}**
- LAN (eth0): **${LAN_IP:-?}**

## Lokale Dienste auf dem RevPi (INPUT)

- TCP Set **IN_TCP**: \`${IN_TCP:-<nicht gefunden>}\`
- UDP Set **IN_UDP**: \`${IN_UDP:-<nicht gefunden>}\`
- FTP Passive Range: \`${FTP_PASV:-<nicht gefunden>}\`

## Listener (laufende Dienste)

| Proto | Local Address | Port | Prozess |
|---|---|---:|---|
$LISTENER_TABLE

### Hinweise
$(printf "%b" "$HINTS")

## Portforwards (DNAT) WAN → LAN

Ziel-IPs (aus DNAT erkannt): ${TARGET_IPS:-<keine>}

| Proto | WAN Port | DNAT Ziel |
|---|---:|---|
${DNAT_TABLE:-| - | - | - |}

## NAT / Masquerading (LAN → WAN)

\`\`\`
${MASQ_LINES:-<kein masquerade gefunden>}
\`\`\`

## Appendix: Konfig-Quellen

### ${TCP_INC}

\`\`\`
${TCP_INC_CONTENT}
\`\`\`

### ${UDP_INC}

\`\`\`
${UDP_INC_CONTENT}
\`\`\`

MD
)

if [[ "$DEBUG" == "1" ]]; then
  {
    echo "### DEBUG"
    echo "NFT=$NFT"
    echo "IP=$IP"
    echo "SS=${SS:-<none>}"
    echo "RULES_LEN=${#RULES}"
    echo "IFACES_LEN=${#IFACES}"
    echo "LISTENERS_LEN=${#LISTENERS_RAW}"
  } >&2
fi

if [[ -n "$OUTFILE" ]]; then
  echo "$REPORT" > "$OUTFILE"
  echo "OK: Report geschrieben nach: $OUTFILE"
else
  echo "$REPORT"
fi

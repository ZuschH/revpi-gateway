# WAN -> LAN TCP Portforwards (DNAT)

# VNC -> 192.168.19.3
iifname "eth1" tcp dport 5800  dnat to 192.168.19.3:5800
iifname "eth1" tcp dport 5900  dnat to 192.168.19.3:5900

# Fuji SX-Programmer -> 192.168.19.1
iifname "eth1" tcp dport 507   dnat to 192.168.19.1:507
iifname "eth1" tcp dport 509   dnat to 192.168.19.1:509

# Hakko (Fuji) V-SFT -> 192.168.19.3
iifname "eth1" tcp dport 8000  dnat to 192.168.19.3:8000
iifname "eth1" tcp dport 8001  dnat to 192.168.19.3:8001
iifname "eth1" tcp dport 10000 dnat to 192.168.19.3:10000
iifname "eth1" tcp dport 10001 dnat to 192.168.19.3:10001
